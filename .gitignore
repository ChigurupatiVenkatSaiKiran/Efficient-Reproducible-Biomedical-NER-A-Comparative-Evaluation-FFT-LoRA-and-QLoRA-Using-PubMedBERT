# ==============================================================
# .gitignore — PubMedBERT BC5CDR PEFT Comparison
# ==============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Virtual environments ─────────────────────────────────────
.env
.venv
env/
venv/
ENV/

# ── Jupyter / IPython ────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.nbconvert.ipynb
profile_default/
ipython_config.py

# ── Large model checkpoints (do NOT commit) ──────────────────
# Trained model weights belong in Google Drive / HuggingFace Hub, not git
checkpoints/
*/checkpoint-*/
runs/
**/pytorch_model.bin
**/model.safetensors
**/optimizer.pt
**/scheduler.pt
**/trainer_state.json
**/training_args.bin

# ── Results cache (large binary) ─────────────────────────────
results/all_results.pkl
results/*.pkl

# ── HuggingFace cache ────────────────────────────────────────
~/.cache/huggingface/
.cache/

# ── OS / IDE ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# JetBrains
.idea/
*.iml

# VS Code
.vscode/
*.code-workspace

# ── Wandb / MLflow experiment tracking ───────────────────────
wandb/
mlruns/

# ── Temp / log files ─────────────────────────────────────────
*.log
*.tmp
*.bak
